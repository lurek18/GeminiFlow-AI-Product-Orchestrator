# --- DATABASE CONFIGURATION ---
# URL tvého Supabase projektu a veřejný API klíč
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_KEY=your_supabase_anon_key
# Cesta k lokální SQLite pro případ výpadku sítě
SQLITE_DB_PATH=./data/fallback.db

# --- AI ENGINE (Gemini 2.0 Flash) ---
# API klíč z Google AI Studio
GEMINI_API_KEY=your_gemini_api_key

# --- E-COMMERCE (WooCommerce) ---
# Adresa e-shopu a REST API klíče
WC_URL=https://vasedomena.cz
WC_CK=ck_xxxx_your_consumer_key
WC_CS=cs_xxxx_your_consumer_secret

# --- MONITORING ---
# Webhook pro zasílání chyb do Slacku nebo Discordu
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- BUSINESS LOGIKA ---
# Marže, která se připočítává k nákupní ceně z XML
PRICE_MARGIN=1.25